{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  "tailwindCSS.includeLanguages": {
    "css": "css",
    "postcss": "css"
  },
  "tailwindCSS.validate": true,
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false
}
